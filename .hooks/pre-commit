#!/bin/sh
test -z "$(git diff --cached --name-only | grep -Ev '^(assets/.*\.json|asm/[0-9a-f]{8}\.s|rom\.sha1)$' | grep -E '(^|/)(baserom|roms?|toolchain|work|out)(/|\.|$)|\.(gba|rom|bin|elf|o|a|s|asm|json|tsv|log)$')" || {
    echo "pure: private inputs and generated artifacts may not be committed" >&2
    exit 1
}
